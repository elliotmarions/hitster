# =====================================================================
#  Hitster Bingo Online – miljövariabler
#  Kopiera denna fil till ".env.local" och fyll i värdena.
#  Alla variabler MÅSTE börja med VITE_ för att Vite ska exponera dem.
# =====================================================================

# --- Supabase (behövs redan i Fas 1) --------------------------------
# Skapa ett gratis projekt på https://supabase.com
# Hämta värdena under: Project Settings -> API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Spotify (behövs först i Fas 3, får vara tomt tills dess) --------
# Registrera en app på https://developer.spotify.com/dashboard
# Kopiera "Client ID" hit:
VITE_SPOTIFY_CLIENT_ID=

# Lägg in EXAKT denna sträng som "Redirect URI" i din Spotify-app.
# OBS: Spotify kräver numera 127.0.0.1 (INTE localhost) för lokal utveckling.
# I produktion byter du till din Vercel-URL, t.ex. https://ditt-projekt.vercel.app/callback
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/callback

# --- Databas-anslutning (VALFRITT – bara för att köra migrationer automatiskt) ---
# OBS: INTE VITE_-prefixad, så den hamnar ALDRIG i frontend-bundlen. Håll den hemlig.
# Hämtas i Supabase: Project Settings -> Database -> Connection string.
# Välj "Session pooler" (bäst kompatibilitet) och byt ut [YOUR-PASSWORD] mot ditt DB-lösenord.
# Läggs bara i .env.local (gitignoreras). Exempel:
# SUPABASE_DB_URL=postgresql://postgres.opvghvjaxqfopyzhpkxb:DITT-LOSEN@aws-0-eu-north-1.pooler.supabase.com:5432/postgres
