# =====================================================================
#  Låtsnurran – miljövariabler
#  Kopiera denna fil till ".env.local" och fyll i värdena.
#  Variabler som ska nå webbläsaren MÅSTE börja med VITE_.
# =====================================================================

# --- Supabase --------------------------------------------------------
# Skapa ett gratis projekt på https://supabase.com
# Hämta värdena under: Project Settings -> API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Databas-anslutning (VALFRITT – bara för att köra migrationer automatiskt) ---
# OBS: INTE VITE_-prefixad, så den hamnar ALDRIG i frontend-bundlen. Håll den hemlig.
# Hämtas i Supabase: Project Settings -> Database -> Connection string.
# Välj "Session pooler" (bäst kompatibilitet) och byt ut [YOUR-PASSWORD] mot ditt DB-lösenord.
# Läggs bara i .env.local (gitignoreras). Exempel:
# SUPABASE_DB_URL=postgresql://postgres.opvghvjaxqfopyzhpkxb:DITT-LOSEN@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
